{
  "name": "volley",
  "version": "1.0.1",
  "private": false,
  "description": "MCP server that lets AI agents perform API testing (REST/GraphQL/WS/SSE/gRPC)",
  "scripts": {
    "build:core": "pnpm --filter @thupham/volley-core build:debug",
    "build:server": "pnpm --filter @thupham/volley-mcp build",
    "build": "pnpm build:core && pnpm build:server",
    "dev": "pnpm --filter @thupham/volley-mcp dev",
    "test:core": "cargo test --manifest-path crates/core/Cargo.toml",
    "e2e": "node scripts/e2e.mjs",
    "release": "bash scripts/release.sh",
    "release:patch": "bash scripts/release.sh patch --tag",
    "release:minor": "bash scripts/release.sh minor --tag",
    "release:major": "bash scripts/release.sh major --tag",
    "publish:local": "bash scripts/release.sh patch --publish-local --no-verify",
    "pub": "bash scripts/publish.sh",
    "pub:core": "bash scripts/publish.sh --core",
    "pub:mcp": "bash scripts/publish.sh --mcp",
    "pub:dry": "bash scripts/publish.sh --dry-run",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "lint:web": "pnpm --filter web lint"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "ws": "^8.18.0"
  },
  "packageManager": "pnpm@11.9.0"
}
